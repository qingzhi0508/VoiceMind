{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoiceMind",
  "identifier": "com.voicemind.voiceinput",
  "version": "0.1.0",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --strictPort",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "VoiceMind",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "center": true,
        "visible": true,
        "dataDirectory": "main"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      },
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}
