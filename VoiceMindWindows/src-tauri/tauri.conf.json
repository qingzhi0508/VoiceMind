{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoiceMind",
  "identifier": "com.voicemind.voiceinput",
  "version": "0.1.0",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --strictPort",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "VoiceMind",
        "width": 1100,
        "height": 750,
        "resizable": true,
        "center": true,
        "visible": true,
        "focus": true,
        "decorations": true,
        "dataDirectory": "main"
      }
    ]
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": [
      "bin/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      },
      "wix": {
        "language": "zh-CN"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/qingzhi0508/VoiceMind/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZEMTFDQjQ3Q0E2RDE3MDAKUldRQUYyM0tSOHNSL1V0Q3dnbnVrMFUzdDc5djF4RjZsRG44ZFQ4eEZVQWpKZjVPRzVRdUN1dmUK"
    }
  }
}
